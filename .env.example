NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
PABBLY_WEBHOOK_SECRET=some-long-random-secret-you-generate
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Deepgram (voice-note transcription — server-only, never NEXT_PUBLIC_)
DEEPGRAM_API_KEY=

# Anthropic (Elaya LLM layer — server-only, never NEXT_PUBLIC_; S-11)
ANTHROPIC_API_KEY=
# Upstash Redis (required — server-only, never NEXT_PUBLIC_)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# Web Push / VAPID (PWA push delivery — generate once with `npx web-push generate-vapid-keys`).
# PRIVATE key + SUBJECT are server-only (never NEXT_PUBLIC_, S-11). The PUBLIC key is also
# exposed to the client (the browser needs it to call pushManager.subscribe) — it is mirrored
# under NEXT_PUBLIC_VAPID_PUBLIC_KEY. Keep both copies of the public key identical.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tech@indulge.global
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

#comment